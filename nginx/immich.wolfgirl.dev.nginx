server {
	server_name immich.wolfgirl.dev;

	listen [::]:443;
	listen 443;
	ssl_certificate    	/etc/letsencrypt/live/immich.wolfgirl.dev/fullchain.pem;
	ssl_certificate_key	/etc/letsencrypt/live/immich.wolfgirl.dev/privkey.pem;
	include /etc/letsencrypt/options-ssl-nginx.conf;
	ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

	# allow large file uploads
	client_max_body_size 50000M;

	# disable buffering uploads to prevent OOM on reverse proxy server and make uploads twice as fast (no pause)
	proxy_request_buffering off;

	# increase body buffer to avoid limiting upload speed
	client_body_buffer_size 1024k;

	# Set headers
	proxy_set_header Host              $host;
	proxy_set_header X-Real-IP         $remote_addr;
	proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
	proxy_set_header X-Forwarded-Proto $scheme;

	# enable websockets: http://nginx.org/en/docs/http/websocket.html
	proxy_http_version 1.1;
	proxy_redirect     off;

	# set timeout
	proxy_read_timeout 600s;
	proxy_send_timeout 600s;
	send_timeout       600s;

	location / {
		proxy_pass http://mammal:2283;
		proxy_set_header   Upgrade    $http_upgrade;
		proxy_set_header   Connection "upgrade";
	}
}

server {
	listen [::]:80;
	listen 80;

	server_name immich.wolfgirl.dev;
	if ($host ~ ^immich\.wolfgirl\.dev$) {
		return 301 https://$host$request_uri;
	}

	return 404;
}
